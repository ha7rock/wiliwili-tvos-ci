+#if defined(TVOS)
+    // WP12: Siri Remote 等 raw joystick 的热插拔 (JOYDEVICE* 对 raw 设备也会触发,
+    // 对 GameController 由 tvRegisterDevice 内的 SDL_IsGameController 判定跳过跟踪)。
