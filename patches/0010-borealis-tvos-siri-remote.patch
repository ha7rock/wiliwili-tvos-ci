--- a/library/lib/platforms/sdl/sdl_input.cpp
+++ b/library/lib/platforms/sdl/sdl_input.cpp
@@ -329,6 +329,212 @@ static const size_t SDL_AXIS_MAPPING[SDL_GAMEPAD_AXIS_MAX] = {
 
 std::vector<std::pair<SDL_JoystickID, SDL_GameController*>> controllers;
 
+#if defined(TVOS)
+// ============================================================================
+// WP12: Siri Remote 最小方向导航兜底 (raw SDL_Joystick 路径)
+// ----------------------------------------------------------------------------
+// 背景 (已查证 SDL2 src/joystick/apple/SDL_mfijoystick.m, 详见 docs/WP12):
+//   * 0004 设 SDL_HINT_TV_REMOTE_AS_JOYSTICK=1 -> Siri Remote 不再被忽略, 作为
+//     joystick / GameController 设备加入 (mfijoystick.m:428 分支)。
+//   * Siri Remote 触摸板"方向"在 SDL 里呈现为 **模拟轴** (Direction Pad X/Y Axis;
+//     旧 microGamepad 路径 axis0=x*32767, axis1=y*-32767, naxes=2/nhats=0),
+//     既不是 dpad 按钮、也不是 hat。因此:
+//       - 若 SDL 建成 GameController 且把这两轴映射到 LEFTX/LEFTY -> 走 borealis 既有
+//         GameController 阈值路径 (sdl_input 526-529), 本兜底不介入 (形态 a/b);
+//       - 若 SDL 未给出可用 GameController 映射 (SDL_IsGameController==false, 即最可能的
+//         "遥控方向完全失效"根因 = Spec 形态 c) -> 既有路径读不到, 由本兜底直接读 raw
+//         SDL_Joystick 的轴 / hat / 按钮补出 BUTTON_NAV_*。
+//   * 手柄永远是 GameController (SDL_IsGameController==true), 绝不进入本兜底 => 手柄零改动。
+//
+// 方向 = **边沿触发**: 记录每设备上一帧在 X/Y 的离散方向 (-1/0/+1), 仅在"越过阈值进入
+// 新非零方向"的那一帧产出一次 NAV 脉冲; 带迟滞回中前不再重复 => 一次拨动 = 一次焦点移动,
+// 避免连续轴造成焦点连跳。hat 同理只在"新按下位"边沿触发。
+// ----------------------------------------------------------------------------
+namespace
+{
+constexpr int TV_AXIS_ENTER = 16000; // 进入阈值 (raw 轴范围 -32768..32767)
+constexpr int TV_AXIS_EXIT  = 8000;  // 迟滞退出阈值
+
+struct TvRemoteAxisState
+{
+    int   lastX   = 0; // 上一帧水平离散方向 (-1 左 / +1 右)
+    int   lastY   = 0; // 上一帧垂直离散方向 (-1 上 / +1 下)
+    Uint8 lastHat = SDL_HAT_CENTERED;
+};
+
+// 我们自行 open 的 raw joystick (非 GameController 设备, 主要是 Siri Remote 形态 c)
+std::vector<std::pair<SDL_JoystickID, SDL_Joystick*>> tvRawJoysticks;
+std::unordered_map<SDL_JoystickID, TvRemoteAxisState>  tvRemoteAxisStates;
+
+bool tvLoggedFirstCtrlInput = false; // GameController 路径首个非零输入是否已打印
+bool tvLoggedFirstRawInput  = false; // raw 路径首个非零输入是否已打印
+
+// 带迟滞的边沿方向判定: 返回本帧离散方向 (-1 / 0 / +1)
+int tvAxisDir(Sint16 v, int last)
+{
+    if (last > 0) return (v >  TV_AXIS_EXIT)  ?  1 : (v < -TV_AXIS_ENTER ? -1 : 0);
+    if (last < 0) return (v < -TV_AXIS_EXIT)  ? -1 : (v >  TV_AXIS_ENTER ?  1 : 0);
+    return (v > TV_AXIS_ENTER) ? 1 : (v < -TV_AXIS_ENTER ? -1 : 0);
+}
+} // namespace
+
+// 枚举诊断: 打印 SDL_IsGameController / 名称 / joystick axes,buttons,hats 数
+static void tvDiagLogDevice(int deviceIndex)
+{
+    const char* jname = SDL_JoystickNameForIndex(deviceIndex);
+    bool isGC         = SDL_IsGameController(deviceIndex) == SDL_TRUE;
+    int naxes = -1, nbtn = -1, nhats = -1;
+    SDL_Joystick* js = SDL_JoystickOpen(deviceIndex); // 若已被 GameController 打开则引用计数+1
+    if (js)
+    {
+        naxes = SDL_JoystickNumAxes(js);
+        nbtn  = SDL_JoystickNumButtons(js);
+        nhats = SDL_JoystickNumHats(js);
+        SDL_JoystickClose(js); // 引用计数-1, 不影响他处已持有的句柄
+    }
+    brls::Logger::info("[tvOS][WP12] device {} \"{}\": IsGameController={} axes={} buttons={} hats={}",
+        deviceIndex, jname ? jname : "(null)", isGC, naxes, nbtn, nhats);
+}
+
+// 注册设备: 打印诊断; 若非 GameController (形态 c) 则持久 open 其 raw joystick 供兜底读取
+static void tvRegisterDevice(int deviceIndex)
+{
+    tvDiagLogDevice(deviceIndex);
+    if (SDL_IsGameController(deviceIndex) == SDL_TRUE)
+        return; // 手柄 / 被识别为 controller 的遥控 -> 既有 GameController 路径处理
+    SDL_Joystick* js = SDL_JoystickOpen(deviceIndex);
+    if (!js)
+        return;
+    SDL_JoystickID jid = SDL_JoystickInstanceID(js);
+    for (auto& p : tvRawJoysticks)
+    {
+        if (p.first == jid) { SDL_JoystickClose(js); return; } // 已跟踪, 撤销多余引用
+    }
+    tvRawJoysticks.push_back({ jid, js });
+    brls::Logger::info("[tvOS][WP12] raw joystick tracked jid={} \"{}\" (Siri Remote 方向兜底已激活)",
+        jid, SDL_JoystickName(js) ? SDL_JoystickName(js) : "(null)");
+}
+
+static void tvUnregisterJoystick(SDL_JoystickID jid)
+{
+    for (auto it = tvRawJoysticks.begin(); it != tvRawJoysticks.end(); ++it)
+    {
+        if (it->first == jid)
+        {
+            if (it->second) SDL_JoystickClose(it->second);
+            tvRawJoysticks.erase(it);
+            tvRemoteAxisStates.erase(jid);
+            brls::Logger::info("[tvOS][WP12] raw joystick removed jid={}", jid);
+            return;
+        }
+    }
+}
+
+// GameController 路径 (形态 a/b) 首个非零输入的一次性诊断 (只读, 不改手柄行为)
+static void tvMaybeLogFirstControllerInput()
+{
+    if (tvLoggedFirstCtrlInput) return;
+    for (auto& c : controllers)
+    {
+        SDL_GameController* gc = c.second;
+        if (!gc) continue;
+        for (int b = 0; b < SDL_CONTROLLER_BUTTON_MAX; b++)
+        {
+            if (SDL_GameControllerGetButton(gc, (SDL_GameControllerButton)b))
+            {
+                brls::Logger::info("[tvOS][WP12] first GameController input: BUTTON idx={} jid={}", b, c.first);
+                tvLoggedFirstCtrlInput = true;
+                return;
+            }
+        }
+        for (int a = 0; a < SDL_CONTROLLER_AXIS_MAX; a++)
+        {
+            int v = SDL_GameControllerGetAxis(gc, (SDL_GameControllerAxis)a);
+            if (v > TV_AXIS_EXIT || v < -TV_AXIS_EXIT)
+            {
+                brls::Logger::info("[tvOS][WP12] first GameController input: AXIS idx={} value={} jid={}", a, v, c.first);
+                tvLoggedFirstCtrlInput = true;
+                return;
+            }
+        }
+    }
+}
+
+// raw joystick 兜底: 边沿触发方向 + 中心点按/Menu 兜底补映射 + 首个非零输入诊断
+static void tvApplySiriRemoteFallback(ControllerState* state)
+{
+    if (tvRawJoysticks.empty()) return;
+    SDL_JoystickUpdate();
+    for (auto& p : tvRawJoysticks)
+    {
+        SDL_Joystick* js = p.second;
+        if (!js || SDL_JoystickGetAttached(js) != SDL_TRUE) continue;
+        SDL_JoystickID jid    = p.first;
+        TvRemoteAxisState& st = tvRemoteAxisStates[jid];
+
+        int naxes = SDL_JoystickNumAxes(js);
+        int nbtn  = SDL_JoystickNumButtons(js);
+        int nhats = SDL_JoystickNumHats(js);
+
+        // --- 首个非零输入诊断 (类型 + 索引 + 值), 一次性 ---
+        if (!tvLoggedFirstRawInput)
+        {
+            for (int a = 0; a < naxes && !tvLoggedFirstRawInput; a++)
+            {
+                Sint16 v = SDL_JoystickGetAxis(js, a);
+                if (v > TV_AXIS_EXIT || v < -TV_AXIS_EXIT)
+                {
+                    brls::Logger::info("[tvOS][WP12] first RAW input: AXIS idx={} value={} jid={}", a, v, jid);
+                    tvLoggedFirstRawInput = true;
+                }
+            }
+            for (int b = 0; b < nbtn && !tvLoggedFirstRawInput; b++)
+                if (SDL_JoystickGetButton(js, b))
+                {
+                    brls::Logger::info("[tvOS][WP12] first RAW input: BUTTON idx={} jid={}", b, jid);
+                    tvLoggedFirstRawInput = true;
+                }
+            for (int h = 0; h < nhats && !tvLoggedFirstRawInput; h++)
+            {
+                Uint8 hv = SDL_JoystickGetHat(js, h);
+                if (hv != SDL_HAT_CENTERED)
+                {
+                    brls::Logger::info("[tvOS][WP12] first RAW input: HAT idx={} value={} jid={}", h, hv, jid);
+                    tvLoggedFirstRawInput = true;
+                }
+            }
+        }
+
+        // --- 轴 -> 边沿触发 NAV (axis0=水平 X, axis1=垂直 Y; SDL 约定 上=负, 见 mfijoystick:1292) ---
+        int curX = 0, curY = 0;
+        if (naxes > 0) curX = tvAxisDir(SDL_JoystickGetAxis(js, 0), st.lastX);
+        if (naxes > 1) curY = tvAxisDir(SDL_JoystickGetAxis(js, 1), st.lastY);
+        if (curX != 0 && curX != st.lastX)
+            state->buttons[curX > 0 ? BUTTON_NAV_RIGHT : BUTTON_NAV_LEFT] = true;
+        if (curY != 0 && curY != st.lastY)
+            state->buttons[curY > 0 ? BUTTON_NAV_DOWN : BUTTON_NAV_UP] = true;
+        st.lastX = curX;
+        st.lastY = curY;
+
+        // --- hat -> 边沿触发 NAV (仅"新按下"的方向位) ---
+        Uint8 hat     = (nhats > 0) ? SDL_JoystickGetHat(js, 0) : (Uint8)SDL_HAT_CENTERED;
+        Uint8 pressed = (Uint8)(hat & ~st.lastHat);
+        if (pressed & SDL_HAT_UP)    state->buttons[BUTTON_NAV_UP]    = true;
+        if (pressed & SDL_HAT_DOWN)  state->buttons[BUTTON_NAV_DOWN]  = true;
+        if (pressed & SDL_HAT_LEFT)  state->buttons[BUTTON_NAV_LEFT]  = true;
+        if (pressed & SDL_HAT_RIGHT) state->buttons[BUTTON_NAV_RIGHT] = true;
+        st.lastHat = hat;
+
+        // --- 确定 / 返回 兜底补映射 (电平触发, 与既有语义一致) ---
+        // microGamepad raw 按钮: idx0 = 中心点按(选择) -> BUTTON_A; 末位通常是 Menu
+        // (pause_button_index = nbuttons-1) -> BUTTON_B。精确索引随 tvOS/OS 版本可能不同,
+        // 需真机验证 (见 docs/WP12 真机清单); A/B 另有既有 controller/键盘路径兜底。
+        if (nbtn > 0 && SDL_JoystickGetButton(js, 0))        state->buttons[BUTTON_A] = true;
+        if (nbtn > 1 && SDL_JoystickGetButton(js, nbtn - 1)) state->buttons[BUTTON_B] = true;
+    }
+}
+#endif // TVOS
+
 static int mouseButtons[3] = { 0 };
 
