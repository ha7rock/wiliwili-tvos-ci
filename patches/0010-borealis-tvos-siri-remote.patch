@@ -395,6 +601,18 @@ static int sdlEventWatcher(void* data, SDL_Event* event)
     {
         keyboardKeys[event->key.keysym.scancode] = event->type == SDL_KEYDOWN ? SDL_PRESSED : SDL_STICKY;
