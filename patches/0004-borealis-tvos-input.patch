     SDL_SetHint(SDL_HINT_ACCELEROMETER_AS_JOYSTICK, "0");
+#if defined(TVOS)
+    // === tvOS Siri Remote 输入策略 (WP5) ===
+    // 默认情况下 tvOS 上 Siri Remote 的 Menu 键、方向点按等由 UIKit 作为
+    // "UI 事件" 处理, SDL 收不到对应的 controller/键盘事件 —— 这会导致
+    // 播放页按 Menu 无法退出 (BUTTON_B 永不触发)。
+    // 设为 "1" 让这些按键作为 SDL GameController / 键盘事件下发, 从而进入
+    // borealis 的 BUTTON_* 映射 (Menu -> SDL_CONTROLLER_BUTTON_B -> BUTTON_B)。
+    // 必须在 SDL_Init / 首次打开 controller 之前设置。
+    SDL_SetHint(SDL_HINT_APPLE_TV_CONTROLLER_UI_EVENTS, "1");
+    // 把 Siri Remote 暴露为一个 joystick/GameController, 方向点按环映射为
+    // dpad, 中心点按映射为 A。设为 "1" (亦为 SDL 默认) 显式声明以防被外部覆盖。
+    SDL_SetHint(SDL_HINT_TV_REMOTE_AS_JOYSTICK, "1");
+    // 禁止把遥控器旋转当作方向输入, 避免误触发导航 (对焦点式 UI 更可控)。
+    SDL_SetHint(SDL_HINT_APPLE_TV_REMOTE_ALLOW_ROTATION, "0");
+#endif
 #elif defined(__APPLE__)
