+// WP8 Bug B: 原子写 —— 先写 <path>.tmp 再 rename 覆盖目标。
+// POSIX rename(2) 对同一文件系统是原子替换, 崩溃时目标要么是旧完整文件、要么是新完整文件,
+// 不会出现"写到一半的半损坏 JSON"(用户实测的永久黑屏根因形态)。
+bool tvosAtomicWrite(const std::string& path, const std::string& content) {
+    const std::string tmp = path + ".tmp";
+    {
+        std::ofstream out(tmp, std::ios::binary | std::ios::trunc);
+        if (!out) return false;
+        out << content;
+        out.flush();
+        if (!out) return false;
+    }
+    std::error_code ec;
+    cpr::fs::rename(tmp, path, ec);
+    if (ec) {
+        // 跨目录/文件系统兜底: 直接覆盖写(非原子, 但优于放弃)。
+        cpr::fs::remove(tmp, ec);
+        std::ofstream out(path, std::ios::binary | std::ios::trunc);
+        if (!out) return false;
+        out << content;
+        return static_cast<bool>(out);
+    }
+    return true;
+}
+} // namespace
+#endif
