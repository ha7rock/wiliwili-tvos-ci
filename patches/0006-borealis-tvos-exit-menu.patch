 void Application::quit()
 {
+#if defined(TVOS)
+    // WP10: tvOS 上唯一允许的主动退出是 "顶层 B -> std::exit(0)"(见 applet_frame.cpp)。
+    // 其余任何走 quit() 的路径(activity registerExitAction / dialog_helper 设置内重启等)
+    // 在 tvOS 一律短路为 no-op —— quitRequested -> Application::exit() 的优雅 teardown 会
+    // 拆除 SDL/GL 上下文, 有残留白帧风险。系统级终止(SDL_QUIT -> mainLoopIteration 返回
+    // false -> Application::exit()) 不经过本函数, 不受影响。
+    return;
+#else
     Application::quitRequested = true;
+#endif
 }
 
 void Application::navigate(FocusDirection direction, bool repeating)
