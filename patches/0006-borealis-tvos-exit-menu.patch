+void SDLPlatform::setTopLevelExitMode(bool atTopLevel)
+{
+#if defined(TVOS)
+    // 顶层 -> "1": Menu 交还系统, 回 tvOS 主屏; 子层 -> "0": Menu 作为 BUTTON_B 进 App 做返回。
+    // SDL_SetHint 内部仅在值变化时触发回调 (SDL_hints.c), 每帧调用安全且廉价。
+    SDL_SetHint(SDL_HINT_APPLE_TV_CONTROLLER_UI_EVENTS, atTopLevel ? "1" : "0");
+#else
+    (void)atTopLevel;
+#endif
+}
